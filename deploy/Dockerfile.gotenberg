FROM gotenberg/gotenberg:8

# TeX Gyre Bonum — FOSS Bookman (GUST license).
# The running template (cert_master_template.docx) references "Bookman Old Style";
# fontconfig substitutes Bonum (its FOSS equivalent) because no real Bookman is shipped.
COPY fonts/texgyrebonum-*.otf /usr/share/fonts/

# Rebuild font cache
USER root
RUN fc-cache -fv
USER gotenberg
